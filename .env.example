# Основная база платформы (квесты, шаги, прогресс)
DATABASE_URL=postgres://sqlquest:sqlquest@localhost:5432/sqlquest

# База-песочница, в которой выполняются запросы игроков.
# Подключение должно идти под read-only ролью (см. db/schema.sql).
SANDBOX_DATABASE_URL=postgres://sqlquest_player:sqlquest_player@localhost:5432/sqlquest_sandbox

# Отправка писем через Resend (https://resend.com/api-keys).
# Замени re_xxxxxxxxx на свой настоящий API-ключ.
RESEND_API_KEY=re_xxxxxxxxx
# Отправитель — адрес на подтверждённом в Resend домене.
# Для локальных экспериментов без домена подойдёт "Скрипткин <onboarding@resend.dev>"
# (письма с него доходят только на email владельца аккаунта Resend).
EMAIL_FROM="Скрипткин <hello@scriptkin.ru>"

# Базовый адрес сайта для ссылок в письмах
SITE_URL=http://localhost:3000
